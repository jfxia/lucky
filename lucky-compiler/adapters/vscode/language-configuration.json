{
    "language-configuration.json": {
        "comments": { "lineComment": "#" },
        "brackets": [
            ["(", ")"],
            ["[", "]"],
            ["{", "}"]
        ],
        "autoClosingPairs": [
            { "open": "(", "close": ")" },
            { "open": "[", "close": "]" },
            { "open": "{", "close": "}" },
            { "open": "\"", "close": "\"" },
            { "open": "\"\"\"", "close": "\"\"\"" }
        ],
        "surroundingPairs": [
            { "open": "(", "close": ")" },
            { "open": "[", "close": "]" },
            { "open": "{", "close": "}" },
            { "open": "\"", "close": "\"" }
        ],
        "indentationRules": {
            "increaseIndentPattern": "^\\s*(agent|task|workflow|goal|policy|permissions|prompt|memory|tool|model|if|else|elif|match|loop|for|parallel|attempt|recover|steps|input|output|context|approval|when|run|success)\\b",
            "decreaseIndentPattern": "^\\s*(else|elif|recover|wait)\\b"
        },
        "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
    }
}
