project StmtTest

task TestStatements
	input
		x: Int
		items: List<String>
	output
		result: String
	steps
		let a = 1
		let b: Int = 2
		const MAX = 100
		const PI: Float = 3.14

		if x > 0
			let msg = "positive"
		else if x == 0
			let msg = "zero"
		else
			let msg = "negative"

		match x
			0 => "zero"
			1 => "one"
			_ => "many"

		loop
			if x <= 0
				break
			x = x - 1

		for item in items
			if item == ""
				continue
			process(item)

		return "done"

task TestParallel
	steps
		parallel
			let a = work_a()
			let b = work_b()
		wait
			let combined = a + b
		return combined

task TestAttemptRecover
	steps
		attempt
			risky_operation()
		recover
			retry 3 with backoff exponential
		recover
			fallback safe_operation()
		recover
			human escalate "Failed after retries"

task TestWhen
	steps
		when
			file_changed
			branch_updated
		run
			rebuild()

