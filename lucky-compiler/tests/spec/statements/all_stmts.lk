project StmtTest

task TestStatements
	input
		x: Int
	output
		result: String
	steps
		let a = 1
		let b: Int = 2
		const MAX = 100
		if a > 0
			let msg = "positive"
		else
			let msg = "negative"
		let step_a = a + 1
		process(step_a)

task TestParallel
	steps
		parallel
			let a = work_a()
			let b = work_b()
		wait
			let combined = a + b
		return combined

task TestAttemptRecover
	steps
		attempt
			risky_operation()
		recover
			retry
		recover
			fallback
		recover
			human_help

task TestWhen
	steps
		when file_changed
		run
			rebuild()
