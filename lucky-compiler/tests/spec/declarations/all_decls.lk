project DeclTest

use DeepSeek

agent ResearchAgent
	model DeepSeek
	memory ProjectMemory
	tools
		Browser, Search, HTTP
	permissions
		allow filesystem.read
		allow git.clone
		allow browser.search
		deny shell.exec

agent CoderAgent
	model GPT
	tools
		Filesystem, Git, Shell
	permissions
		allow filesystem.read
		allow filesystem.write
		deny shell.exec

task AnalyzeRepo
	input
		repo: URI
		depth: Int
	output
		report: String
		score: Float
	steps
		let data = "analyzing repo"
		return data

task SafeTask
	input
		input_file: String
	output
		output_file: String
	steps
		let content = ""
		return content

goal BuildProject
	success
		project_built
		tests_passed
	workflow MainWorkflow
	workflow QuickWorkflow

workflow MainWorkflow
	ResearchAgent
	CoderAgent
	SafeTask(input_file = "config.toml")

memory ProjectMemory
	scope project
	backend vector

model LocalLLM(provider = "ollama", version = "llama3.1")

prompt ResearchPrompt
	role
		You are a research agent
	rules
		- Cite all sources
		- Prefer academic papers

policy StandardPolicy
	retry 3
	timeout 10m

type IntList = List
