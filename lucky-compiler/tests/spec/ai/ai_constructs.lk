project AITest

use DeepSeek

model MainModel(provider = "deepseek")
model BackupModel(provider = "openai", version = "gpt-4o")

prompt CodeReviewer
	role
		You are a senior software engineer
	rules
		- Report actionable findings
		- Rate severity

prompt Summarizer
	role
		Summarize the following text

agent SmartAgent
	model MainModel
	memory AgentMemory
	tools
		Search, Browser
	permissions
		allow browser.search
		allow http.get
		deny filesystem.write
	prompt CodeReviewer

memory AgentMemory
	scope session
	backend vector

task AIOperations
	steps
		let answer = "AI result"
		let summary = "Summary text"
		ask DeepSeek:
			let result = "explanation"
		reason deep
		use GPT
		let conf = answer
		return answer
