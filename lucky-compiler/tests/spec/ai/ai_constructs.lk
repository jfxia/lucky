project AITest

use Claude

model MainModel(
    provider = "anthropic",
    version = "claude-sonnet-4-20250514",
    temperature = 0.7,
    max_tokens = 4096
)

model BackupModel(
    provider = "openai",
    version = "gpt-4o"
)

prompt CodeReviewer
    role
        You are a senior software engineer.
    rules
        - Report actionable findings
        - Rate severity low/medium/high/critical
    examples
        input:
            SELECT * FROM users WHERE id = 1
        output:
            severity: low
            finding: Use parameterized queries

prompt Summarizer
    role
        Summarize the following text.

agent SmartAgent
    model MainModel
    memory AgentMemory
    tools
        Search, Browser
    permissions
        allow browser.search
        allow http.get
        deny filesystem.write
    prompt CodeReviewer

memory AgentMemory
    scope session
    backend vector
    dimensions 768

knowledge CompanyDocs
    source "./docs/**/*.md"
    source uri("https://docs.example.com")

context ProjectContext
    user: String
    repo: URI
    session: String

permissions AgentPerms
    allow
        filesystem.read
        git.clone
        http.get
    deny
        filesystem.delete
        shell.exec

approval BeforeDeploy
    before deploy
    timeout 4h escalate manager

task AIOperations
    steps
        let answer = ai.ask("What is Lucky?")
        let summary = ai.summarize("long text", SummarizeOptions(max_words = 50))
        let sentiment = ai.sentiment("I love this!")

        ask Claude:
            Explain the architecture.

        reason deep

        use GPT

        let conf = answer confidence > 0.8

        return answer.value
